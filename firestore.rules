rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== Helper Functions ====================
    
    // Check if the request is from an authenticated user
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the user is an admin (by email)
    function isAdmin() {
      return isSignedIn() && 
        request.auth.token.email in [
          'admin@shreeshyammobiles.com',
          // Add your admin email addresses here
        ];
    }
    
    // Validate that a field is a string with max length
    function isValidString(field, maxLength) {
      return field is string && field.size() <= maxLength;
    }
    
    // Rate limiting: max 10 reads per minute per user
    // (Firestore doesn't support this natively — use App Check + Cloud Functions)
    
    // ==================== Products ====================
    match /products/{productId} {
      // Public: Anyone can read products
      allow read: if true;
      
      // Admin only: Create, Update, Delete
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ==================== Banners ====================
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==================== Brands ====================
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==================== Categories ====================
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==================== Offers ====================
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==================== Daily Deals ====================
    match /dailyDeals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // ==================== Orders ====================
    match /orders/{orderId} {
      // Orders are sensitive — only authenticated users can read their own
      allow read: if isAdmin() || 
        (isSignedIn() && resource.data.customer.email == request.auth.token.email);
      
      // Anyone can create an order (for guest checkout)
      allow create: if true;
      
      // Only admin can update/delete orders
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ==================== User Profiles (future) ====================
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // ==================== Deny all other collections ====================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
